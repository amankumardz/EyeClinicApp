@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-shell py-4 py-md-5">
    <div class="row g-4 align-items-center">
        <div class="col-lg-5 order-lg-2">
            <div class="auth-hero p-4 p-xl-5">
                <span class="auth-badge mb-3">New here?</span>
                <h1 class="display-6 fw-semibold mb-3">Create your clinic account in minutes.</h1>
                <p class="text-white-50 mb-0">Book appointments faster, monitor status updates, and save your preferences for your next visit.</p>
            </div>
        </div>
        <div class="col-lg-7 order-lg-1">
            <div class="auth-card p-4 p-xl-5">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                    <div>
                        <h2 class="h3 mb-1">Create account</h2>
                        <p class="text-muted mb-0">Let's get your profile ready.</p>
                    </div>
                    <a class="btn btn-soft btn-sm rounded-pill px-3" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Log in</a>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="vstack gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div>
                        <label asp-for="Input.FullName" class="form-label"></label>
                        <input asp-for="Input.FullName" class="form-control form-control-lg" placeholder="Your full name" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="new-password" aria-required="true" placeholder="Create a password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" aria-required="true" placeholder="Repeat password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-brand btn-lg w-100">Create account</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
