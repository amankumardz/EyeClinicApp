@model EyeClinicApp.Models.Glass
@{
    ViewData["Title"] = "Add Glasses";
}

<h1 class="mb-4">Add Glasses</h1>

<form asp-action="AddGlass" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
        <span asp-validation-for="Brand" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Category" class="form-label"></label>
        <select asp-for="Category" class="form-select">
            @foreach (var category in (IEnumerable<string>)(ViewBag.GlassCategories ?? Array.Empty<string>()))
            {
                <option value="@category">@category</option>
            }
        </select>
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="imageFile" class="form-label">Glass Image</label>
        <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
        <span class="text-danger" data-valmsg-for="imageFile" data-valmsg-replace="true"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
