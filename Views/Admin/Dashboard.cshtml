@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>

<div class="row g-3 mt-2">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Total Glasses</h5>
                <p class="display-6">@ViewData["GlassesCount"]</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Total Appointments</h5>
                <p class="display-6">@ViewData["AppointmentsCount"]</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="ManageGlasses" class="btn btn-outline-primary">Manage Glasses</a>
    <a asp-action="ManageAppointments" class="btn btn-outline-secondary">Manage Appointments</a>
</div>
