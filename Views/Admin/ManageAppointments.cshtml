@model IEnumerable<EyeClinicApp.Models.Appointment>
@{
    ViewData["Title"] = "Manage Appointments";

    string GetStatusClass(string status) => status switch
    {
        "Pending" => "badge-pending",
        "Approved" => "badge-approved",
        "Rejected" => "badge-rejected",
        "Modified" => "badge-modified",
        "Completed" => "badge-completed",
        _ => "badge-modified"
    };
}

<div class="dashboard-shell fade-in">
    <aside class="dashboard-sidebar panel-card">
        <h6 class="text-uppercase text-secondary small fw-semibold">Admin Navigation</h6>
        <nav class="nav flex-column mt-2 gap-1">
            <a asp-action="Dashboard" class="nav-link"><i class="bi bi-grid me-2"></i>Dashboard</a>
            <a asp-action="ManageAppointments" class="nav-link active"><i class="bi bi-calendar3 me-2"></i>Appointments</a>
            <a asp-action="ManageGlasses" class="nav-link"><i class="bi bi-eyeglasses me-2"></i>Glasses</a>
        </nav>
    </aside>

    <section>
        <div class="page-head">
            <div>
                <h1 class="mb-1">Manage Appointments</h1>
                <p class="text-secondary mb-0">Review, approve, reject, or modify patient appointment requests.</p>
            </div>
        </div>

        @if (Model is null || !Model.Any())
        {
            <div class="alert alert-info">No appointments are currently scheduled.</div>
        }
        else
        {
            <div class="admin-table-wrap">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Date</th>
                                <th>Slot</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@appointment.Name</td>
                                    <td>@appointment.PhoneNumber</td>
                                    <td>@(appointment.Email ?? "N/A")</td>
                                    <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(appointment.TimeSlot?.GetDisplayLabel() ?? "N/A")</td>
                                    <td><span class="badge-status @GetStatusClass(appointment.Status)">@appointment.Status</span></td>
                                    <td>
                                        <div class="d-flex flex-wrap justify-content-end gap-1">
                                            <form asp-action="ChangeStatus" method="post">
                                                <input type="hidden" name="id" value="@appointment.Id" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button class="btn btn-sm btn-success" type="submit">Approve</button>
                                            </form>
                                            <form asp-action="ChangeStatus" method="post">
                                                <input type="hidden" name="id" value="@appointment.Id" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button class="btn btn-sm btn-danger" type="submit">Reject</button>
                                            </form>
                                            <a asp-action="EditAppointment" asp-route-id="@appointment.Id" class="btn btn-sm btn-soft">Modify</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</div>
