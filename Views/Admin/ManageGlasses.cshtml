@model IEnumerable<EyeClinicApp.Models.Glass>
@{
    ViewData["Title"] = "Manage Glasses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Manage Glasses</h1>
    <a asp-action="AddGlass" class="btn btn-primary">Add New Glasses</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No glasses have been added yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Brand</th>
                <th class="text-end">Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var glass in Model)
            {
                <tr>
                    <td>@glass.Name</td>
                    <td>@glass.Brand</td>
                    <td class="text-end">@glass.Price.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
