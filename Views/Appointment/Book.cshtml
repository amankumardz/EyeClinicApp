@using EyeClinicApp.Models
@model EyeClinicApp.ViewModels.BookAppointmentSlotSelectionViewModel
@{
    ViewData["Title"] = "Book Appointment - Step 1";
}

<div class="booking-shell fade-in">
    <div class="booking-head mb-3">
        <h1 class="h3 mb-1">Step 1: Choose Date &amp; Slot</h1>
        <p class="text-secondary mb-0">Pick any available 30-minute slot from the next 7 days.</p>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success border-0 shadow-sm">@success</div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger border-0 shadow-sm">@error</div>
    }

    <form asp-action="Book" method="post" id="slotSelectionForm" class="booking-card">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <input asp-for="SelectedDate" type="hidden" id="selectedDateInput" />

        <div class="date-tabs-wrap">
            <div class="date-tabs" id="dateTabs">
                @foreach (var tab in Model.DateTabs)
                {
                    <button type="button"
                            class="date-tab @(tab.IsSelected ? "active" : "")"
                            data-date="@tab.Date.ToString("yyyy-MM-dd")"
                            aria-pressed="@(tab.IsSelected.ToString().ToLowerInvariant())"
                            disabled="@tab.IsDisabled">
                        @tab.Label
                    </button>
                }
            </div>
        </div>

        <div class="mt-4">
            @foreach (var shiftGroup in Model.ShiftGroups)
            {
                <section class="shift-card mb-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h2 class="h5 mb-0">@shiftGroup.Shift Shift</h2>
                        <span class="text-secondary small">@shiftGroup.Slots.Count slot(s)</span>
                    </div>

                    @if (shiftGroup.Slots.Any())
                    {
                        <div class="slot-grid">
                            @foreach (var slot in shiftGroup.Slots)
                            {
                                var isSelected = Model.SelectedSlotId == slot.Id;
                                var stateClass = slot.IsBooked ? "booked" : isSelected ? "selected" : "available";
                                <label class="slot-item status-@stateClass">
                                    <input type="radio"
                                           asp-for="SelectedSlotId"
                                           value="@slot.Id"
                                           disabled="@slot.IsBooked" />
                                    <span class="slot-pill">
                                        <span class="slot-time">@slot.Label</span>
                                        <small class="slot-status">@((slot.IsBooked) ? "Booked" : "Available")</small>
                                    </span>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-shift">No slots configured for @shiftGroup.Shift shift.</div>
                    }
                </section>
            }
        </div>

        @if (!Model.ShiftGroups.SelectMany(g => g.Slots).Any(s => !s.IsBooked))
        {
            <div class="alert alert-warning mb-2">No slots available for the selected date.</div>
        }

        <span asp-validation-for="SelectedSlotId" class="text-danger small d-block mb-2"></span>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-brand px-4" id="continueBtn">
                Continue to Details
            </button>
            <a asp-action="Book" class="btn btn-soft">Reset</a>
        </div>
        <div class="loading-state mt-2" id="loadingState" hidden>
            <span class="spinner-border spinner-border-sm me-2"></span>Loading slots...
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const tabs = document.querySelectorAll('.date-tab[data-date]');
            const dateInput = document.getElementById('selectedDateInput');
            const loading = document.getElementById('loadingState');
            const continueBtn = document.getElementById('continueBtn');
            const form = document.getElementById('slotSelectionForm');

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => {
                    if (!dateInput) return;
                    dateInput.value = tab.dataset.date;
                    if (loading) loading.hidden = false;
                    window.location.href = `@Url.Action("Book", "Appointment")?date=${tab.dataset.date}`;
                });
            });

            if (form) {
                form.addEventListener('submit', () => {
                    if (continueBtn) continueBtn.disabled = true;
                    if (loading) loading.hidden = false;
                });
            }
        })();
    </script>
}
