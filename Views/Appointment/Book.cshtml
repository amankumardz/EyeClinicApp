@model EyeClinicApp.ViewModels.BookAppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row g-4 align-items-start">
    <div class="col-lg-4 fade-in">
        <div class="panel-card p-4">
            <h1 class="h3 mb-3">Book an Appointment</h1>
            <p class="text-secondary mb-3">Pick your preferred date and slot in less than a minute.</p>
            <div class="d-flex align-items-center gap-2 text-secondary small">
                <i class="bi bi-shield-check"></i>
                <span>Secure request. Admin approval required.</span>
            </div>
        </div>
    </div>

    <div class="col-lg-8 fade-in" style="animation-delay:.08s;">
        @if (TempData["Success"] is string successMessage)
        {
            <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
        }

        <form asp-action="Book" method="post" class="booking-card">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Name" class="form-control" placeholder="Full Name" />
                        <label asp-for="Name"></label>
                    </div>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                        <label asp-for="PhoneNumber"></label>
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <label asp-for="Email"></label>
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Age" class="form-control" placeholder="Age" />
                        <label asp-for="Age"></label>
                    </div>
                    <span asp-validation-for="Age" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-floating">
                        <input asp-for="Address" class="form-control" placeholder="Address" />
                        <label asp-for="Address"></label>
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-floating">
                        <textarea asp-for="ReasonForVisit" class="form-control" placeholder="Reason for Visit" style="height: 110px;"></textarea>
                        <label asp-for="ReasonForVisit"></label>
                    </div>
                    <span asp-validation-for="ReasonForVisit" class="text-danger small"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="AppointmentDate" class="form-label fw-semibold">Preferred Date</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-calendar-event input-icon"></i>
                        <input asp-for="AppointmentDate" class="form-control" type="date" min="@DateTime.UtcNow.Date.AddDays(1).ToString("yyyy-MM-dd")" />
                    </div>
                    <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                </div>

                <div class="col-md-7">
                    <label class="form-label fw-semibold">Select Time Slot</label>
                    @if (Model.AvailableSlots is not null && Model.AvailableSlots.Any())
                    {
                        <div class="slot-grid">
                            @foreach (var slot in Model.AvailableSlots)
                            {
                                var isSelected = Model.TimeSlotId?.ToString() == slot.Value;
                                <label class="slot-item">
                                    <input type="radio" asp-for="TimeSlotId" value="@slot.Value" checked="@isSelected" />
                                    <span class="slot-pill">@slot.Text</span>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-secondary small">No slots are available for this date. Try another day.</div>
                    }
                    <span asp-validation-for="TimeSlotId" class="text-danger small d-block mt-1"></span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-brand px-4">Book Appointment</button>
                <a asp-action="Book" asp-route-date="@Model.AppointmentDate.ToString("yyyy-MM-dd")" class="btn btn-soft">Refresh Slots</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
