@model EyeClinicApp.ViewModels.BookAppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment - Step 2";
}

<div class="row g-4 align-items-start">
    <div class="col-lg-4 fade-in">
        <div class="panel-card p-4">
            <h1 class="h4 mb-3">Step 2: Patient Details</h1>
            <p class="text-secondary mb-3">Complete your booking details and confirm your slot.</p>

            <div class="selection-summary">
                <div><strong>Date:</strong> @Model.AppointmentDate.ToString("dd MMM yyyy")</div>
                <div><strong>Time:</strong> @Model.SelectedTimeSlotLabel</div>
            </div>
        </div>
    </div>

    <div class="col-lg-8 fade-in" style="animation-delay:.08s;">
        <form asp-action="Confirm" method="post" class="booking-card">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <input asp-for="AppointmentDate" type="hidden" />
            <input asp-for="TimeSlotId" type="hidden" />
            <input asp-for="SelectedTimeSlotLabel" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Name" class="form-control" placeholder="Full Name" />
                        <label asp-for="Name"></label>
                    </div>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                        <label asp-for="PhoneNumber"></label>
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <label asp-for="Email"></label>
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Age" class="form-control" placeholder="Age" />
                        <label asp-for="Age"></label>
                    </div>
                    <span asp-validation-for="Age" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-floating">
                        <input asp-for="Address" class="form-control" placeholder="Address" />
                        <label asp-for="Address"></label>
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-floating">
                        <textarea asp-for="ReasonForVisit" class="form-control" placeholder="Reason" style="height: 110px;"></textarea>
                        <label asp-for="ReasonForVisit"></label>
                    </div>
                    <span asp-validation-for="ReasonForVisit" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-brand px-4">Confirm Booking</button>
                <a asp-action="Book" asp-route-date="@Model.AppointmentDate.ToString("yyyy-MM-dd")" class="btn btn-soft">Back to Slots</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
