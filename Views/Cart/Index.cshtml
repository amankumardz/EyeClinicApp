@model EyeClinicApp.ViewModels.CartPageViewModel
@{
    ViewData["Title"] = "My Cart";
}

<div class="page-head mb-4">
    <div>
        <h1 class="mb-1">My Cart</h1>
        <p class="text-secondary mb-0">Review your selected eyewear before checkout.</p>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">Your cart is empty.</div>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var item in Model.Items)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body d-flex flex-column flex-md-row gap-3 align-items-md-center">
                        <div style="width: 90px;">
                            @if (!string.IsNullOrWhiteSpace(item.ImageBase64))
                            {
                                <img src="data:image/jpeg;base64,@item.ImageBase64" class="img-fluid rounded" alt="@item.Name" />
                            }
                            else
                            {
                                <img src="~/images/placeholders/product.svg" class="img-fluid rounded" alt="@item.Name" />
                            }
                        </div>

                        <div class="flex-grow-1">
                            <h5 class="mb-1">@item.Name</h5>
                            <div class="text-secondary">Unit Price: @item.Price.ToString("C")</div>
                            <div class="fw-semibold">Line Total: @item.LineTotal.ToString("C")</div>
                        </div>

                        <div class="d-flex flex-column gap-2" style="min-width: 220px;">
                            <form asp-action="UpdateQuantity" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <input type="number" name="quantity" min="1" value="@item.Quantity" class="form-control" />
                                <button class="btn btn-outline-primary" type="submit">Update</button>
                            </form>

                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <button class="btn btn-danger w-100" type="submit">Remove</button>
                            </form>
                        </div>
                    </div>
                    <div class="border-top mt-3 pt-3">
                        <form asp-action="UpdateLens" method="post" class="row g-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <div class="col-md-2"><input class="form-control form-control-sm" name="rightEyeSph" value="@item.RightEyeSph" placeholder="OD SPH" /></div>
                            <div class="col-md-2"><input class="form-control form-control-sm" name="rightEyeCyl" value="@item.RightEyeCyl" placeholder="OD CYL" /></div>
                            <div class="col-md-2"><input class="form-control form-control-sm" name="rightEyeAxis" value="@item.RightEyeAxis" placeholder="OD Axis" /></div>
                            <div class="col-md-2"><input class="form-control form-control-sm" name="leftEyeSph" value="@item.LeftEyeSph" placeholder="OS SPH" /></div>
                            <div class="col-md-2"><input class="form-control form-control-sm" name="leftEyeCyl" value="@item.LeftEyeCyl" placeholder="OS CYL" /></div>
                            <div class="col-md-2"><input class="form-control form-control-sm" name="leftEyeAxis" value="@item.LeftEyeAxis" placeholder="OS Axis" /></div>
                            <div class="col-12"><button class="btn btn-outline-secondary btn-sm" type="submit">Save Lens Values</button></div>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm sticky-top" style="top: 96px;">
                <div class="card-body">
                    <h4>Order Summary</h4>
                    <hr />
                    <div class="d-flex justify-content-between mb-3">
                        <span>Total</span>
                        <strong>@Model.Total.ToString("C")</strong>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary w-100">Proceed to Checkout</a>
                </div>
            </div>
        </div>
    </div>
}
