@model IEnumerable<EyeClinicApp.Models.Glass>
@{
    ViewData["Title"] = "Eyewear Catalog";
}

@if (TempData["CartMessage"] is string cartMessage)
{
    <div class="alert alert-success">@cartMessage</div>
}

<div class="page-head fade-in">
    <div>
        <h1 class="mb-1">Eyewear Catalog</h1>
        <p class="text-secondary mb-0">Discover premium frames with modern comfort and timeless styling.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-soft btn-sm" type="button"><i class="bi bi-funnel me-1"></i>Filters</button>
        <button class="btn btn-soft btn-sm" type="button"><i class="bi bi-arrow-down-up me-1"></i>Sort</button>
    </div>
</div>

@if (Model is null || !Model.Any())
{
    <div class="alert alert-info">No glasses are available right now.</div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-6 col-lg-4 col-xl-3 fade-in">
                <article class="product-card">
                    <div class="product-media">
                        @if (!string.IsNullOrWhiteSpace(item.ImageBase64))
                        {
                            <img src="data:image/jpeg;base64,@item.ImageBase64" alt="@item.Name" />
                        }
                        else
                        {
                            <img src="~/images/placeholders/product.svg" alt="No image available" />
                        }
                    </div>
                    <div class="p-3 p-lg-4 d-flex flex-column h-100">
                        <p class="text-uppercase text-secondary small mb-1">@item.Brand</p>
                        <h5 class="mb-2">@item.Name</h5>
                        <p class="text-secondary small flex-grow-1">@item.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="price-tag">@item.Price.ToString("C")</span>
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="glassId" value="@item.Id" />
                                <button type="submit" class="btn btn-brand btn-sm px-3">Add to Cart</button>
                            </form>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
