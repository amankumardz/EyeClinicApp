@model IEnumerable<EyeClinicApp.Models.Glass>
@{
    ViewData["Title"] = "Eyewear Catalog";
    var selectedCategory = (ViewBag.SelectedCategory as string) ?? string.Empty;
    var categories = (IEnumerable<string>)(ViewBag.Categories ?? new[] { "Men", "Women", "Kids" });
}

@if (TempData["CartMessage"] is string cartMessage)
{
    <div class="alert alert-success">@cartMessage</div>
}

<section class="catalog-page mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h1 class="section-title mb-0">Eyewear Catalog</h1>
        @if (!string.IsNullOrWhiteSpace(selectedCategory))
        {
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-soft btn-sm">Clear Filter</a>
        }
    </div>

    <div class="category-section">
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="Men" class="category-card @(selectedCategory == "Men" ? "active" : string.Empty)">Men</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="Women" class="category-card @(selectedCategory == "Women" ? "active" : string.Empty)">Women</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="Kids" class="category-card @(selectedCategory == "Kids" ? "active" : string.Empty)">Kids</a>
    </div>
</section>

<section>
    <div class="page-head fade-in">
        <div>
            <h2 class="mb-1">Explore Collection</h2>
            <p class="text-secondary mb-0">Premium styles curated for comfort, confidence, and every face shape.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-soft btn-sm @(string.IsNullOrWhiteSpace(selectedCategory) ? "active-filter" : string.Empty)">All</a>
            @foreach (var category in categories)
            {
                <a asp-controller="Catalog" asp-action="Index" asp-route-category="@category" class="btn btn-soft btn-sm @(selectedCategory == category ? "active-filter" : string.Empty)">@category</a>
            }
        </div>
    </div>

    @if (Model is null || !Model.Any())
    {
        <div class="alert alert-info">No products found for this category. Try another filter.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3 fade-in">
                    <article class="product-card product-card--interactive lenskart-card">
                        <div class="product-media product-media--interactive">
                            @if (!string.IsNullOrWhiteSpace(item.ImageBase64))
                            {
                                <img src="data:image/jpeg;base64,@item.ImageBase64" alt="@item.Name" />
                            }
                            else
                            {
                                <img src="~/images/placeholders/product.svg" alt="No image available" />
                            }

                            <button type="button" class="wishlist-btn" aria-label="Add @item.Name to wishlist">
                                <i class="bi bi-heart"></i>
                            </button>

                            <div class="product-overlay">
                                <div class="d-grid gap-2">
                                    @if (User.Identity?.IsAuthenticated ?? false)
                                    {
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-100">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="glassId" value="@item.Id" />
                                            <button type="submit" class="btn btn-primary add-to-cart-btn w-100">
                                                <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary add-to-cart-btn w-100" title="Sign in to add this item to your cart">
                                            <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                        </a>
                                    }
                                    <button type="button" class="btn btn-light btn-sm">Quick View</button>
                                </div>
                            </div>
                        </div>
                        <div class="p-3 p-lg-4 d-flex flex-column h-100">
                            <p class="text-uppercase text-secondary small mb-1">@item.Brand</p>
                            <h5 class="mb-1">@item.Name</h5>
                            <p class="text-secondary small mb-2">@item.Category Collection</p>
                            <p class="text-secondary small flex-grow-1">@item.Description</p>

                            <div class="d-flex justify-content-between align-items-center gap-2 mt-2">
                                <span class="price-tag">₹@item.Price.ToString("0.00")</span>
                                <span class="badge text-bg-light border">Free Lenses</span>
                            </div>

                            <div class="add-to-cart-mobile mt-3">
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-grid">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="glassId" value="@item.Id" />
                                        <button type="submit" class="btn btn-primary add-to-cart-btn">
                                            <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary add-to-cart-btn w-100" title="Sign in to add this item to your cart">
                                        <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                    </a>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
