@model IEnumerable<EyeClinicApp.Models.Appointment>
<h2>Doctor Dashboard</h2>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead><tr><th>Date</th><th>Patient</th><th>Slot</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AppointmentDate.ToString("dd MMM yyyy")</td>
                <td>@(item.User?.FullName ?? item.Name)</td>
                <td>@item.TimeSlot?.GetDisplayLabel()</td>
                <td>@item.Status</td>
                <td class="text-end">
                    <div class="d-inline-flex gap-1">
                        @if (item.Prescription is null)
                        {
                            <a asp-action="AddPrescription" asp-route-appointmentId="@item.Id" class="btn btn-sm btn-primary">Add Prescription</a>
                        }
                        else
                        {
                            <span class="badge bg-success align-self-center">Prescription Added</span>
                        }
                        @if (item.Status != EyeClinicApp.Models.AppointmentStatus.Completed)
                        {
                            <form asp-action="MarkComplete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appointmentId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Mark Complete</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
