@model IEnumerable<EyeClinicApp.Models.Appointment>
<h2>Doctor Dashboard</h2>
<table class="table table-striped">
    <thead><tr><th>Date</th><th>Patient</th><th>Slot</th><th>Prescription</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.AppointmentDate.ToString("dd MMM yyyy")</td>
            <td>@item.Name</td>
            <td>@item.TimeSlot?.GetDisplayLabel()</td>
            <td>
                @if (item.Prescription is null)
                {
                    <a asp-action="UploadPrescription" asp-route-appointmentId="@item.Id" class="btn btn-sm btn-primary">Upload</a>
                }
                else
                {
                    <span class="badge bg-success">Uploaded</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
