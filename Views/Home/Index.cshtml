@model EyeClinicApp.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero-panel p-4 p-lg-5 mb-4 fade-in">
    <div class="row align-items-center g-4">
        <div class="col-lg-7 hero-copy">
            <span class="badge rounded-pill text-bg-light mb-3">Premium Vision Experience</span>
            <h1 class="display-5 fw-bold mb-3">Style-forward eyewear and easy online appointments.</h1>
            <p class="fs-5 text-white-50 mb-4">Discover curated frames, schedule eye checkups, and manage everything from one modern dashboard.</p>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-brand btn-lg px-4" asp-controller="Appointment" asp-action="Book">
                    <i class="bi bi-calendar-check me-2"></i>Book Appointment
                </a>
                <a class="btn btn-light btn-lg px-4" asp-controller="Catalog" asp-action="Index">
                    <i class="bi bi-grid me-2"></i>Explore Catalog
                </a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="panel-card p-4 bg-white bg-opacity-10 border-0 text-white">
                <h5 class="fw-semibold">Why Patients Choose EyeClinic</h5>
                <ul class="small mb-0 ps-3 mt-3">
                    <li class="mb-2">Same-day slot visibility with smooth booking.</li>
                    <li class="mb-2">Premium frame catalog with clear pricing.</li>
                    <li>Admin workflow for approvals, edits, and tracking.</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="mb-4 fade-in" style="animation-delay: .08s;">
    <div class="page-head">
        <div>
            <h2 class="section-title mb-1">Quick Actions</h2>
            <p class="text-secondary mb-0">Everything you need in just one click.</p>
        </div>
    </div>

    <div class="row g-3 g-lg-4">
        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <div class="feature-icon mb-3"><i class="bi bi-calendar2-heart"></i></div>
                <h5>Book Appointment</h5>
                <p class="text-secondary">Choose date and slots with an intuitive, mobile-friendly form.</p>
                <a asp-controller="Appointment" asp-action="Book" class="btn btn-soft mt-2">Book Now</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <div class="feature-icon mb-3"><i class="bi bi-people"></i></div>
                <h5>Meet Our Team</h5>
                <p class="text-secondary">Explore specialist doctors, optometrists, and clinic support staff.</p>
                <a asp-controller="Team" asp-action="Index" class="btn btn-soft mt-2">View Team</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100 p-4">
                <div class="feature-icon mb-3"><i class="bi bi-chat-square-quote"></i></div>
                <h5>Client Reviews</h5>
                <p class="text-secondary">Read trusted testimonials from patients who visited our clinic.</p>
                <a asp-controller="Review" asp-action="Index" class="btn btn-soft mt-2">Read Reviews</a>
            </div>
        </div>
    </div>
</section>

<section class="mb-3 fade-in" style="animation-delay: .12s;">
    <div class="page-head">
        <div>
            <h2 class="section-title mb-1">Top Client Reviews</h2>
            <p class="text-secondary mb-0">Showing our latest approved testimonials.</p>
        </div>
        <a asp-controller="Review" asp-action="Index" class="btn btn-soft">View All Reviews</a>
    </div>

    <div class="row g-3 g-lg-4">
        @if (Model.TopReviews.Count == 0)
        {
            <div class="col-12">
                <div class="panel-card p-4 text-secondary">No approved reviews available yet.</div>
            </div>
        }
        else
        {
            @foreach (var review in Model.TopReviews)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="review-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@(string.IsNullOrWhiteSpace(review.ClientImageBase64) ? Url.Content("~/images/placeholders/person.svg") : $"data:image/jpeg;base64,{review.ClientImageBase64}")" alt="@review.ClientName" class="avatar-mini" />
                            <div>
                                <h6 class="mb-0">@review.ClientName</h6>
                                <small class="text-warning">@string.Concat(Enumerable.Repeat("⭐", review.Rating))</small>
                            </div>
                        </div>
                        <p class="text-secondary mb-0">@review.ReviewText</p>
                    </article>
                </div>
            }
        }
    </div>
</section>
