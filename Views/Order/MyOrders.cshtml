@model EyeClinicApp.ViewModels.MyOrdersViewModel
@{
    ViewData["Title"] = "My Orders";
}

<h1 class="mb-4">My Orders</h1>

@if (Model.Orders.Count == 0)
{
    <div class="alert alert-info">You have not placed any orders yet.</div>
}
else
{
    foreach (var order in Model.Orders)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Order #@order.OrderId</h5>
                    <span class="badge bg-primary">@order.Status</span>
                </div>
                <p class="text-secondary mb-2">Placed on @order.CreatedAt.ToLocalTime().ToString("f")</p>
                <ul class="mb-2">
                    @foreach (var item in order.Items)
                    {
                        <li>@item.Name — @item.Quantity x @item.Price.ToString("C")</li>
                    }
                </ul>
                <strong>Total: @order.TotalAmount.ToString("C")</strong>
            </div>
        </div>
    }
}
