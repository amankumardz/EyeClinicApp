@model IReadOnlyCollection<EyeClinicApp.Models.Review>
@{
    ViewData["Title"] = "Manage Reviews";
}

<div class="page-head">
    <div>
        <h1 class="mb-1">Manage Reviews</h1>
        <p class="text-secondary mb-0">Approve, edit, or remove client testimonials.</p>
    </div>
    <a asp-action="Create" class="btn btn-brand"><i class="bi bi-plus-circle me-2"></i>Add Review</a>
</div>

<div class="admin-table-wrap p-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Rating</th>
                    <th>Review</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@item.ClientImageUrl" alt="@item.ClientName" class="avatar-mini" />
                                <span class="fw-semibold">@item.ClientName</span>
                            </div>
                        </td>
                        <td class="text-warning">@string.Concat(Enumerable.Repeat("⭐", item.Rating))</td>
                        <td class="text-secondary">@item.ReviewText</td>
                        <td>
                            <span class="badge @(item.IsApproved ? "text-bg-success" : "text-bg-secondary")">@(item.IsApproved ? "Approved" : "Rejected")</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft">Edit</a>
                            <form asp-action="ToggleApproval" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-soft">@(item.IsApproved ? "Reject" : "Approve")</button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this review?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
