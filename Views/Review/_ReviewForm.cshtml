@model EyeClinicApp.Models.Review

<form method="post" enctype="multipart/form-data" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="ClientName" class="form-label"></label>
        <input asp-for="ClientName" class="form-control" />
        <span asp-validation-for="ClientName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Rating" class="form-label"></label>
        <input asp-for="Rating" class="form-control" />
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label for="imageFile" class="form-label">Client Image</label>
        <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
        <span class="text-danger" asp-validation-for="ClientImageBase64"></span>
        @if (!string.IsNullOrWhiteSpace(Model.ClientImageBase64))
        {
            <img src="data:image/jpeg;base64,@Model.ClientImageBase64" alt="Current client image" class="avatar-mini mt-2" />
        }
    </div>
    <div class="col-12">
        <label asp-for="ReviewText" class="form-label"></label>
        <textarea asp-for="ReviewText" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ReviewText" class="text-danger"></span>
    </div>
    <div class="col-12 form-check">
        <input asp-for="IsApproved" class="form-check-input" />
        <label asp-for="IsApproved" class="form-check-label"></label>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-brand">Save</button>
        <a asp-action="Manage" class="btn btn-soft">Back</a>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />
