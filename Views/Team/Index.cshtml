@model IReadOnlyCollection<EyeClinicApp.Models.PersonProfile>
@{
    ViewData["Title"] = "Our Team";
}

<section class="page-head mb-4">
    <div>
        <h1 class="mb-1">Our Team</h1>
        <p class="text-secondary mb-0">Meet our doctors, optometrists, and clinic professionals.</p>
    </div>
</section>

<div class="row g-4">
    @foreach (var member in Model)
    {
        <div class="col-md-6 col-xl-4">
            <article class="team-card h-100">
                <img src="@(string.IsNullOrWhiteSpace(member.ProfileImageBase64) ? Url.Content("~/images/placeholders/person.svg") : $"data:image/jpeg;base64,{member.ProfileImageBase64}")" alt="@member.Name" class="team-avatar" />
                <div class="p-4">
                    <span class="badge text-bg-light mb-2">@member.Role</span>
                    <h5 class="mb-1">@member.Name</h5>
                    <p class="text-secondary mb-2">@member.ExperienceYears years experience</p>
                    <p class="mb-0 text-secondary">@(string.IsNullOrWhiteSpace(member.Bio) ? "Dedicated team member providing quality eye care support." : member.Bio)</p>
                </div>
            </article>
        </div>
    }
</div>
