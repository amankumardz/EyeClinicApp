@model IReadOnlyCollection<EyeClinicApp.Models.PersonProfile>
@{
    ViewData["Title"] = "Manage Team";
}

<div class="page-head">
    <div>
        <h1 class="mb-1">Manage Team</h1>
        <p class="text-secondary mb-0">Create and maintain doctor, optometrist, and staff profiles.</p>
    </div>
    <a asp-action="Create" class="btn btn-brand"><i class="bi bi-plus-circle me-2"></i>Add Profile</a>
</div>

<div class="admin-table-wrap p-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Experience</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(string.IsNullOrWhiteSpace(item.ProfileImageBase64) ? Url.Content("~/images/placeholders/person.svg") : $"data:image/jpeg;base64,{item.ProfileImageBase64}")" alt="@item.Name" class="avatar-mini" />
                                <div>
                                    <p class="fw-semibold mb-0">@item.Name</p>
                                    <small class="text-secondary">@item.Qualification</small>
                                </div>
                            </div>
                        </td>
                        <td>@item.Role</td>
                        <td>@item.ExperienceYears yrs</td>
                        <td>
                            <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft">Edit</a>
                            <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-soft">@(item.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this profile?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
